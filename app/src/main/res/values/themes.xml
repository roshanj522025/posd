<resources>
    <style name="Theme.ProotDroid" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/accent_green</item>
        <item name="colorPrimaryDark">@color/bg_dark</item>
        <item name="colorAccent">@color/accent_green</item>
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:statusBarColor">@color/bg_surface</item>
        <item name="android:navigationBarColor">@color/bg_surface</item>
    </style>

    <style name="Theme.ProotDroid.Splash" parent="Theme.ProotDroid">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">false</item>
    </style>

    <!-- Quick-key button style used in terminal -->
    <style name="QuickKey" parent="Widget.AppCompat.Button.Borderless">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">36dp</item>
        <item name="android:layout_marginEnd">2dp</item>
        <item name="android:paddingHorizontal">10dp</item>
        <item name="android:textColor">#8B949E</item>
        <item name="android:textSize">11sp</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:background">@drawable/bg_quick_key</item>
        <item name="android:minWidth">0dp</item>
    </style>
</resources>
