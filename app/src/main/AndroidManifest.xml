<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="ProotDroid"
        android:roundIcon="@mipmap/ic_launcher"
        android:supportsRtl="true"
        android:theme="@style/Theme.ProotDroid"
        android:hardwareAccelerated="true"
        android:largeHeap="true">

        <activity
            android:name=".ui.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.ProotDroid.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.SetupActivity"
            android:exported="false" />

        <activity
            android:name=".ui.ConsoleActivity"
            android:exported="false"
            android:configChanges="orientation|keyboardHidden|screenSize" />

        <activity
            android:name=".ui.MainActivity"
            android:exported="false"
            android:configChanges="orientation|keyboardHidden|screenSize|screenLayout"
            android:windowSoftInputMode="adjustResize" />

        <!-- Foreground service — dataSync is available from API 24 with no extra declaration -->
        <service
            android:name=".proot.ProotService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

    </application>
</manifest>
