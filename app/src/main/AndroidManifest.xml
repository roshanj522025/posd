<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Network access for bootstrap download -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Storage for the rootfs -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="29" />

    <!-- Foreground service to keep proot running -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Wake lock to prevent CPU sleep during long operations -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="ProotDroid"
        android:roundIcon="@mipmap/ic_launcher"
        android:supportsRtl="true"
        android:theme="@style/Theme.ProotDroid"
        android:hardwareAccelerated="true"
        android:largeHeap="true">

        <!-- Splash / Launcher -->
        <activity
            android:name=".ui.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.ProotDroid.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Main terminal/VNC host -->
        <activity
            android:name=".ui.MainActivity"
            android:exported="false"
            android:configChanges="orientation|keyboardHidden|screenSize|screenLayout"
            android:windowSoftInputMode="adjustResize" />

        <!-- Terminal activity -->
        <activity
            android:name=".terminal.TerminalActivity"
            android:exported="false"
            android:configChanges="orientation|keyboardHidden|screenSize"
            android:windowSoftInputMode="adjustResize" />

        <!-- VNC Viewer activity -->
        <activity
            android:name=".vnc.VncActivity"
            android:exported="false"
            android:configChanges="orientation|keyboardHidden|screenSize"
            android:screenOrientation="landscape" />

        <!-- Foreground service for PRoot session -->
        <service
            android:name=".proot.ProotService"
            android:exported="false"
            android:foregroundServiceType="specialUse" />

        <!-- Bootstrap installer service -->
        <service
            android:name=".proot.BootstrapService"
            android:exported="false" />

    </application>
</manifest>
